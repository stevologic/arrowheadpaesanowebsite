{
  "name": "arrowhead-paesano",
  "version": "1.0.0",
  "private": true,
  "description": "Static Hugo site for the Arrowhead Paesano YouTube channel",
  "scripts": {
    "build": "hugo --gc --minify",
    "dev": "hugo server --bind 127.0.0.1 --port 1515 --baseURL http://localhost:1515/ --disableFastRender --renderToMemory"
  },
  "devDependencies": {
    "hugo-bin": "^0.149.2"
  },
  "engines": {
    "node": ">=18"
  },
  "allowScripts": {
    "hugo-bin@0.149.2": true
  }
}
