# Optional override. The verified Arrowhead Paesano channel ID below is also the built-in default.
YOUTUBE_CHANNEL_ID=UCZfgwB3XweP-PehJYiQFfNw

# Cache TTL in minutes for news feeds. Lower = fresher, higher = less load on upstream feeds.
FEED_CACHE_MINUTES=15

# Optional: load live merch and create checkout carts through Shopify's
# Storefront API. Use the permanent *.myshopify.com domain, not a custom domain.
# The static catalog remains visible until both the domain and token are set.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-04

# Optional: limit the catalog to one Shopify collection handle.
SHOPIFY_COLLECTION_HANDLE=

# Shopify catalog cache TTL in minutes. Stale products are served on API errors.
SHOPIFY_CACHE_MINUTES=10

# Optional: Amazon Associates tracking for the curated Chiefs shopping searches.
# Paste the tracking ID exactly as supplied by Amazon. Leave blank for untagged links.
AMAZON_ASSOCIATE_TAG=

# Optional Amazon hostname. Only the US marketplace is supported.
AMAZON_MARKETPLACE=www.amazon.com

PORT=1515
